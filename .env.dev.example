# Example local development env file for Terraform
# Copy to .env.dev and fill real values

# HCP Terraform user token
TF_TOKEN_app_terraform_io=<terraform-cloud-user-token>

TF_VAR_cloudflare_api_token=<cloudflare-api-token>
TF_VAR_cloudflare_account_id=<cloudflare-account-id>
TF_VAR_cloudflare_zone_id=<cloudflare-zone-id>
TF_VAR_azure_location=uksouth
TF_VAR_route_pattern=example.com/*
TF_VAR_manage_apex_dns_record=true
TF_VAR_apex_dns_record_content=192.0.2.1
TF_VAR_api_custom_hostname=api-staging.freedomtimes.news
TF_VAR_api_custom_hostname_certificate_base64=
TF_VAR_api_custom_hostname_certificate_password=

# Optional explicit staging/prod overrides for GitHub vars automation
TF_VAR_azure_location_staging=
TF_VAR_route_pattern_staging=
TF_VAR_worker_name_staging=
TF_VAR_manage_apex_dns_record_staging=
TF_VAR_apex_dns_record_content_staging=
TF_VAR_api_custom_hostname_staging=
TF_VAR_api_custom_hostname_production=api.freedomtimes.news
TF_VAR_manage_apex_dns_record_production=true
TF_VAR_apex_dns_record_content_production=192.0.2.1
TF_VAR_api_custom_hostname_certificate_base64_staging=
TF_VAR_api_custom_hostname_certificate_password_staging=
TF_VAR_api_custom_hostname_certificate_base64_production=
TF_VAR_api_custom_hostname_certificate_password_production=

# Worker runtime non-secret vars
AUTH0_API_AUDIENCE_PRODUCTION=https://api.freedomtimes.news
API_BASE_URL_PRODUCTION=https://api.freedomtimes.news/editorial
COOKIE_BASE_DOMAIN=freedomtimes.news
COOKIE_BASE_DOMAIN_STAGING=freedomtimes.news
COOKIE_BASE_DOMAIN_PRODUCTION=freedomtimes.news
AUTH0_ROLES_CLAIM_NAMESPACE=https://freedomtimes.news
AUTH0_ROLES_CLAIM_NAMESPACE_STAGING=https://freedomtimes.news
AUTH0_ROLES_CLAIM_NAMESPACE_PRODUCTION=https://freedomtimes.news
API_UPSTREAM_MODE_STAGING=apim
API_UPSTREAM_MODE_PRODUCTION=apim

# Azure credentials for Terraform azurerm provider
ARM_CLIENT_ID=<azure-service-principal-client-id>
ARM_CLIENT_SECRET=<azure-service-principal-client-secret>
ARM_SUBSCRIPTION_ID=<azure-subscription-id>
ARM_TENANT_ID=<azure-tenant-id>

# Optional page content overrides
TF_VAR_worker_name=freedomtimes-holding
TF_VAR_holding_title=Freedom Times
TF_VAR_holding_heading=Freedom Times
TF_VAR_holding_message=We are preparing the site. Please check back soon.
TF_VAR_build_revision=
TF_VAR_contact_email=

# Auth0 — Terraform provider credentials (M2M app)
# See NON_TERRAFORM_RESOURCES.md for setup instructions
TF_VAR_auth0_domain=<auth0-tenant>.uk.auth0.com
TF_VAR_auth0_client_id=<freedomtimes-terraform M2M client-id>
TF_VAR_auth0_client_secret=<freedomtimes-terraform M2M client-secret>

# Auth0 application credentials for Worker runtime login flow
# Staging and production each use their own Regular Web App client secret.
AUTH0_LOGIN_APP_CLIENT_ID_STAGING=<freedomtimes-staging app client-id>
AUTH0_LOGIN_APP_CLIENT_SECRET_STAGING=<freedomtimes-staging app client-secret>
AUTH0_LOGIN_APP_CLIENT_ID_PRODUCTION=<freedomtimes-production app client-id>
AUTH0_LOGIN_APP_CLIENT_SECRET_PRODUCTION=<freedomtimes-production app client-secret>
