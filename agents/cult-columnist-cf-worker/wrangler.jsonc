{
	"name": "cult-columnist-cf-worker",
	"main": "src/index.ts",
	"compatibility_date": "2025-04-01",
	"compatibility_flags": ["nodejs_compat"],

	// Non-sensitive config shared across environments
	"vars": {
		"AUTH0_API_AUDIENCE": "https://api.freedomtimes.news",
		"AUTH0_ROLES_CLAIM_NAMESPACE": "https://freedomtimes.news/roles"
	},

	// Secrets (never in wrangler.jsonc):
	//   AUTH0_DOMAIN      — set via: wrangler secret put AUTH0_DOMAIN
	//   DIRECTUS_URL      — set via: wrangler secret put DIRECTUS_URL
	//   DIRECTUS_TOKEN    — set via: wrangler secret put DIRECTUS_TOKEN
	// Sync all from .env.dev via:
	//   .\scripts\set-github-secrets.ps1 -Target Staging -SyncCloudflareWorkerSecrets

	"durable_objects": {
		"bindings": [
			{
				"name": "ORCHESTRATOR",
				"class_name": "CultAgentOrchestrator"
			},
			{
				"name": "RUN_PROGRESS_HUB",
				"class_name": "RunProgressHub"
			}
		]
	},

	// Cron disabled during spike — trigger runs manually via POST /runs/start
	// "triggers": { "crons": ["0 */12 * * *"] },

	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["CultAgentOrchestrator"]
		},
		{
			"tag": "v2",
			"new_sqlite_classes": ["RunProgressHub"]
		}
	],
	"queues": {
		"producers": [
			{
				"binding": "CANDIDATE_FETCH_QUEUE",
				"queue": "cult-candidate-fetch-staging"
			}
		],
		"consumers": [
			{
				"queue": "cult-candidate-fetch-staging",
				"max_batch_size": 25,
				"max_batch_timeout": 5
			}
		]
	},

	"env": {
		"local": {
			"vars": {
				"AUTH0_API_AUDIENCE": "https://api.freedomtimes.news",
				"AUTH0_ROLES_CLAIM_NAMESPACE": "https://freedomtimes.news/roles"
			},
			// Secrets for local dev: copy .dev.vars.example to .dev.vars and fill in values.
			"durable_objects": {
				"bindings": [
					{
						"name": "ORCHESTRATOR",
						"class_name": "CultAgentOrchestrator"
					},
					{
						"name": "RUN_PROGRESS_HUB",
						"class_name": "RunProgressHub"
					}
				]
			},
			"d1_databases": [
				{
					"binding": "AGENT_DB",
					"database_name": "cult-agent-db-local",
					"database_id": "local"
				}
			],
			"r2_buckets": [
				{
					"binding": "AGENT_STORE",
					"bucket_name": "cult-agent-store-local"
				}
			],
			"queues": {
				"producers": [
					{
						"binding": "CANDIDATE_FETCH_QUEUE",
						"queue": "cult-candidate-fetch-local"
					}
				],
				"consumers": [
					{
						"queue": "cult-candidate-fetch-local",
						"max_batch_size": 25,
						"max_batch_timeout": 5
					}
				]
			}
		},
		"staging": {
			"name": "cult-columnist-cf-worker-staging",
			"vars": {
				"AUTH0_API_AUDIENCE": "https://api.freedomtimes.news",
				"AUTH0_ROLES_CLAIM_NAMESPACE": "https://freedomtimes.news/roles"
			},
			"d1_databases": [
				{
					"binding": "AGENT_DB",
					"database_name": "cult-agent-db-staging",
					"database_id": "REPLACE_WITH_D1_ID"
				}
			],
			"r2_buckets": [
				{
					"binding": "AGENT_STORE",
					"bucket_name": "cult-agent-store-staging"
				}
			],
			"queues": {
				"producers": [
					{
						"binding": "CANDIDATE_FETCH_QUEUE",
						"queue": "cult-candidate-fetch-staging"
					}
				],
				"consumers": [
					{
						"queue": "cult-candidate-fetch-staging",
						"max_batch_size": 25,
						"max_batch_timeout": 5
					}
				]
			}
		}
	}
}
