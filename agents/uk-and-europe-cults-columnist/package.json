{
  "name": "uk-and-europe-cults-columnist",
  "version": "0.1.0",
  "private": true,
  "description": "Local agent to draft UK/EU cult-related CMS posts via MCP",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx --env-file=.env src/index.ts",
    "dev": "cmd /c \"set DISCOVERY_MAX_AGE_HOURS=168&& set GOOGLE_NEWS_WATCHLIST_SITE_OR_CHUNK=1&& .\\node_modules\\.bin\\tsx.cmd --env-file=.env src/index.ts\"",
    "pipeline:only": "cmd /c \"set SKIP_DISCOVERY=true&& set DISCOVERY_MAX_AGE_HOURS=168&& .\\node_modules\\.bin\\tsx.cmd src/index.ts\"",
    "render:html": "tsx --env-file=.env scripts/render-cult-news-html.tsx",
    "render:cult-news": "tsx --env-file=.env scripts/render-cult-news-html.tsx",
    "feedback:server": "tsx --env-file=.env scripts/feedback-server.mts",
    "backup:before-run": "tsx scripts/backup-before-run.ts",
    "recover:failed-urls": "tsx scripts/recover-failed-urls.ts",
    "probe:locale": "tsx --env-file=.env scripts/probe-locale-queries.mts",
    "probe:publisher-langs": "tsx scripts/probe-publisher-homepage-langs.ts",
    "split:discovery-groups": "node scripts/split-discovery-query-groups.mjs",
    "analyze:google-news-query-plan": "node scripts/analyze-google-news-query-plan.mjs",
    "replay:rejection-review-html": "tsx scripts/replay-rejection-review-from-log.ts",
    "export:candidates": "tsx scripts/export-candidate-urls.ts",
    "render:rejection-review-html": "node scripts/render-pipeline-rejection-review-html.mjs",
    "snapshot:html": "cmd /c powershell -Command \"Copy-Item reports/cult-news-latest.html reports/cult-news-snapshot.html -Force; Write-Host 'Snapshot saved to reports/cult-news-snapshot.html'\"",
    "diff:html": "node scripts/diff-cult-news-reports.mjs reports/cult-news-latest.html reports/cult-news-snapshot.html",
    "e2e:smoke": "cmd /c scripts\\run-e2e-smoke.cmd 5",
    "e2e:full": "cmd /c \"cd /d %CD% && set AGENT_ENV=staging && set DISCOVERY_MAX_AGE_HOURS=168 && set DRY_RUN=true && npx tsx src/index.ts\"",
    "test:clusters": "tsx --env-file=.env scripts/cluster-integration.test.mts",
    "test:clusters:fixture": "cmd /c \"set CLUSTER_TEST_USE_FIXTURE=1&& tsx --env-file=.env scripts/cluster-integration.test.mts\"",
    "test:digest-exclusion": "tsx --env-file=.env scripts/digest-exclusion.test.mts",
    "test:digest-exclusion:fixture": "cmd /c \"set DIGEST_TEST_SKIP_LIVE=1&& tsx --env-file=.env scripts/digest-exclusion.test.mts\"",
    "sync:cluster-regression": "tsx --env-file=.env scripts/sync-cluster-regression.mts",
    "build:cluster-modifiers": "tsx scripts/build-cluster-modifier-terms.mts",
    "build:cluster-modifiers:seeds": "tsx scripts/build-cluster-modifier-terms.mts --seeds-only --strip-lang-fields",
    "build:review-report": "tsx --env-file=.env scripts/build-review-report.mts",
    "refetch:review-report": "tsx --env-file=.env scripts/refetch-review-report.mts",
    "test:article-extraction": "tsx scripts/article-extraction.test.mts",
    "test:report-proper-nouns": "tsx scripts/report-proper-nouns.test.mts",
    "cluster:print-expectations": "tsx scripts/cluster-print-expectations.mts",
    "draft:collect-images": "tsx scripts/collect-roundup-image-candidates.mts",
    "draft:upload-images": "tsx scripts/upload-roundup-images.mts",
    "draft:inject-images": "tsx scripts/inject-roundup-images.mts",
    "draft:probe-images": "tsx scripts/probe-roundup-image-candidates.mts",
    "draft:push-staging": "tsx scripts/push-draft-to-staging.mts",
    "test:image-quality": "tsx scripts/image-quality.test.mts"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/node-fetch": "^2.6.13",
    "node-fetch": "^3.3.2",
    "socks-proxy-agent": "^10.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "google-news-url-decoder": "^1.2.1",
    "playwright": "^1.59.1",
    "tinyld": "^1.3.4"
  }
}
