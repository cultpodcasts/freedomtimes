# Example staging-only local env overlay
# Copy to .env.staging and fill real values
# Local dev reads these keys directly. Do not use prefixed alias names.

# [github-secrets]
AUTH0_LOGIN_APP_CLIENT_ID=<freedomtimes-staging app client-id>
AUTH0_LOGIN_APP_CLIENT_SECRET=<freedomtimes-staging app client-secret>
TF_VAR_api_custom_hostname_certificate_base64=
TF_VAR_api_custom_hostname_certificate_password=

# [github-vars]
TF_VAR_azure_location=uksouth
TF_VAR_route_pattern=staging.example.com/*
TF_VAR_worker_name=freedomtimes-holding-staging
TF_VAR_manage_apex_dns_record=false
TF_VAR_apex_dns_record_content=192.0.2.1
TF_VAR_api_custom_hostname=api-staging.example.com
COOKIE_BASE_DOMAIN=example.com
AUTH0_ROLES_CLAIM_NAMESPACE=https://example.com
API_UPSTREAM_MODE=apim

# [cloudflare-worker-secrets]
AUTH0_DOMAIN=<auth0-tenant>.uk.auth0.com
AUTH0_CLIENT_ID=<freedomtimes-staging app client-id>
AUTH0_CLIENT_SECRET=<freedomtimes-staging app client-secret>
AUTH0_API_AUDIENCE=https://api.freedomtimes.news
API_BASE_URL=https://staging-api.freedomtimes.news
TF_VAR_route_pattern=staging.freedomtimes.news/*
TF_VAR_api_custom_hostname=api-staging.freedomtimes.news
COOKIE_BASE_DOMAIN=freedomtimes.news
AUTH0_ROLES_CLAIM_NAMESPACE=https://freedomtimes.news
