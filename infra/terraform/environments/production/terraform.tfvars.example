cloudflare_account_id = "<cloudflare-account-id>"
cloudflare_zone_id    = "<cloudflare-zone-id>"
azure_location        = "uksouth"
route_pattern         = "example.com/*"

# Auth0 app workspace URL for production auth callbacks
workspace_url = "https://example.com"

worker_name     = "freedomtimes-holding"
holding_title   = "Freedom Times"
holding_heading = "Freedom Times"
holding_message = "We are preparing the site. Please check back soon."
contact_email   = ""

enable_editorial_easy_auth      = true
enable_editorial_gateway_policy = true
editorial_roles_claim           = "https://example.com/roles"
editorial_allowed_roles         = ["admin", "editor"]
api_management_sku_name         = "Consumption_0"
api_management_api_path         = "editorial"
api_custom_hostname             = "api.example.com"

# APIM custom hostname certificate (PFX) material for gateway TLS
# Provide these via environment variables or secure workspace vars in CI/Terraform Cloud.
# api_custom_hostname_certificate_base64 = "<base64-pfx>"
# api_custom_hostname_certificate_password = "<pfx-password>"

# Node.js version for Azure Functions
node_version = "24"

# Provide EmDash database URL via environment variable (for example Neon):
# TF_VAR_emdash_database_url = "postgresql://user:password@ep-...neon.tech/dbname?sslmode=require"

# Import existing Neon resources before enabling management.
manage_neon_resources = false
neon_branch_name      = "main"
neon_role_name        = "neondb_owner"
neon_database_name    = "neondb"
# TF_VAR_neon_api_key = "<neon-api-key>"
# TF_VAR_neon_project_id = "<project-id>"
# TF_VAR_neon_branch_id = "<branch-id>"
# TF_VAR_neon_endpoint_id = "<endpoint-id>"
