{
  "name": "web",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "build": "tsx scripts/build-service-worker.ts && astro build && tsx scripts/patch-cloudflare-bundle.ts",
    "scheduler:db:migrate": "tsx scripts/apply-turso-sql.ts scheduler migrate",
    "scheduler:db:seed": "tsx scripts/apply-turso-sql.ts scheduler seed",
    "scheduler:db:deploy": "tsx scripts/apply-turso-sql.ts scheduler migrate && tsx scripts/apply-turso-sql.ts scheduler seed",
    "subscriptions:db:migrate": "tsx scripts/apply-turso-sql.ts subscriptions migrate",
    "subscriptions:db:migrate:staging": "tsx scripts/apply-turso-sql.ts subscriptions migrate --staging",
    "subscriptions:db:seed": "tsx scripts/apply-turso-sql.ts subscriptions seed",
    "subscriptions:db:deploy": "tsx scripts/apply-turso-sql.ts subscriptions migrate && tsx scripts/apply-turso-sql.ts subscriptions seed",
    "subscriptions:db:deploy:staging": "tsx scripts/apply-turso-sql.ts subscriptions migrate --staging && tsx scripts/apply-turso-sql.ts subscriptions seed --staging",
    "tips:db:migrate": "tsx scripts/apply-turso-sql.ts tips migrate",
    "tips:db:migrate:staging": "tsx scripts/apply-turso-sql.ts tips migrate --staging",
    "tips:db:deploy": "tsx scripts/apply-turso-sql.ts tips migrate",
    "tips:db:deploy:staging": "tsx scripts/apply-turso-sql.ts tips migrate --staging",
    "subscriptions:db:backfill-sent-articles": "tsx scripts/backfill-sent-article-notifications.ts",
    "subscriptions:env-keys": "node scripts/lib/turso-env-bindings.mjs",
    "subscriptions:inspect": "node scripts/inspect-push-notifications.mjs",
    "subscriptions:list": "node scripts/inspect-push-notifications.mjs --list",
    "subscriptions:reset-sent-article": "node scripts/reset-sent-article-notification.mjs",
    "subscriptions:send-test": "node scripts/send-test-push-notification.mjs",
    "subscriptions:compare-vapid-keys": "node scripts/compare-push-vapid-keys.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "android:launcher-icons": "node scripts/generate-android-launcher-icons.mjs",
    "build:service-worker": "tsx scripts/build-service-worker.ts",
    "cap:doctor": "cap doctor",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync:android": "cap sync android",
    "cap:sync:ios": "cap sync ios",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "deploy:staging:workers": "pwsh -NoProfile -File ../scripts/deploy-staging-workers-only.ps1"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@astrojs/react": "^5.0.7",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@emdash-cms/cloudflare": "^0.27.0",
    "@libsql/client": "^0.17.4",
    "@libsql/kysely-libsql": "^0.4.1",
    "astro": "^7.0.2",
    "drizzle-orm": "^0.45.2",
    "emdash": "^0.27.0",
    "jose": "^6.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@capacitor/cli": "^8.4.1",
    "@napi-rs/canvas": "^0.1.80",
    "@resvg/resvg-js": "^2.6.2",
    "esbuild": "^0.25.3",
    "mcp-remote": "^0.1.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.4.296",
    "satori": "^0.26.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "webpush-webcrypto": "^1.0.5"
  },
  "allowScripts": {
    "better-sqlite3@12.9.0": true,
    "sharp@0.34.5": true,
    "workerd@1.20260623.1": true,
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true
  }
}
