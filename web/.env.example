AUTH0_DOMAIN=your-tenant.example-auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_API_AUDIENCE=
API_BASE_URL=
COOKIE_BASE_DOMAIN=example.com
AUTH0_ROLES_CLAIM_NAMESPACE=https://example.com
API_UPSTREAM_MODE=apim
CAPACITOR_SERVER_URL=https://staging.freedomtimes.news

# Admin analytics (Workers Analytics Engine SQL API) — see web/docs/ADMIN_ANALYTICS.md
# Dataset id: terraform output page_views_dataset (do not invent ad-hoc ids).
# Query auth: REQUIRED ANALYTICS_CF_TOKEN in repo-root .env.dev (Account Analytics Read).
# Terraform pushes Worker secret CLOUDFLARE_ANALYTICS_API_TOKEN — it does not mint tokens.
# Never reuse TF_VAR_CLOUDFLARE_API_TOKEN for analytics.
#   pwsh scripts/terraform-run.ps1 -Environment staging -Operation apply -LoadEnvFiles
# Local-only Worker env overrides (normally unset — secrets come from Terraform):
# CLOUDFLARE_ANALYTICS_API_TOKEN=
# PAGE_VIEWS_DATASET=
