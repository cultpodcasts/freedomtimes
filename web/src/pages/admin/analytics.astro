---
import AnalyticsCountryLabel from '../../components/admin/AnalyticsCountryLabel.astro';
import Header from '../../components/Header.astro';
import Layout from '../../layouts/Layout.astro';
import { requireAdminDashboardSession } from '../../lib/admin-dashboard-session';
import {
	loadAdminAnalytics,
	parseAnalyticsPathFilter,
	parseAnalyticsRange,
	type AnalyticsRange,
} from '../../lib/page-view-analytics';

export const prerender = false;

const auth = await requireAdminDashboardSession({
	cookies: Astro.cookies,
	url: Astro.url,
	request: Astro.request,
	redirect: Astro.redirect,
});

if (auth instanceof Response) {
	return auth;
}

const range = parseAnalyticsRange(Astro.url.searchParams.get('range'));
const includeBots = Astro.url.searchParams.get('includeBots') === '1';
const selectedPath = parseAnalyticsPathFilter(Astro.url.searchParams.get('path'));
const panelParam = Astro.url.searchParams.get('panel');
/** Mobile single-panel view; desktop always shows both columns. */
const activePanel: 'pages' | 'countries' =
	panelParam === 'pages' || panelParam === 'countries'
		? panelParam
		: selectedPath
			? 'countries'
			: 'pages';

const analytics = await loadAdminAnalytics({
	range,
	excludeBots: !includeBots,
	path: selectedPath,
});

const countryRows = selectedPath ? analytics.pathCountries : analytics.countries;

const ranges: { id: AnalyticsRange; label: string }[] = [
	{ id: '1d', label: '1 day' },
	{ id: '1w', label: '1 week' },
	{ id: '1m', label: '1 month' },
];

function analyticsHref(opts: {
	range?: AnalyticsRange;
	includeBots?: boolean;
	path?: string | null;
	/** Omit to keep current mobile panel; pass null to drop `panel` from the URL. */
	panel?: 'pages' | 'countries' | null;
}): string {
	const params = new URLSearchParams();
	params.set('range', opts.range ?? range);
	if (opts.includeBots ?? includeBots) {
		params.set('includeBots', '1');
	}
	const path = opts.path === undefined ? selectedPath : opts.path;
	if (path) {
		params.set('path', path);
	}
	const panel = opts.panel === undefined ? activePanel : opts.panel;
	// Only persist panel when it differs from the default derived from path
	// (avoids noisy URLs on desktop while keeping mobile view stable across filters).
	const defaultPanel = path ? 'countries' : 'pages';
	if (panel && panel !== defaultPanel) {
		params.set('panel', panel);
	}
	return `/admin/analytics?${params.toString()}`;
}
---

<Layout
	title="Site traffic"
	description="Public page view analytics for Freedom Times."
	canonicalUrl={Astro.url.href}
>
	<Header section="Site traffic" isAdmin={true} isSignedIn={true} />
	<article class="analytics-admin">
		<p class="back">
			<a href="/admin">← Admin</a>
		</p>
		<h1>Site traffic</h1>

		<section class="analytics" aria-labelledby="analytics-heading">
			<div class="analytics__header">
				<h2 id="analytics-heading" class="visually-hidden">Public page views</h2>
				<p class="analytics__eyebrow">Public page views</p>
				<p class="analytics__meta">
					This page is the viewer only; <code>/admin</code>, APIs, and EmDash are not counted.
					Backend Cloudflare Analytics Engine aggregates (no frontend tracker). Path, country, and
					bot flag only — no IPs or User-Agents stored. Retention ~3 months. Click a top page to
					see its country breakdown.
				</p>
			</div>

			<nav class="analytics__ranges" aria-label="Public page view timeframe">
				{ranges.map((item) => (
					<a
						href={analyticsHref({ range: item.id })}
						class:list={['analytics__range', { 'is-active': item.id === range }]}
						aria-current={item.id === range ? 'page' : undefined}
					>
						{item.label}
					</a>
				))}
			</nav>

			<p class="analytics__filters">
				{includeBots ? (
					<>
						Including likely bots.{' '}
						<a href={analyticsHref({ includeBots: false })}>Hide bots</a>
					</>
				) : (
					<>
						Likely bots hidden by default.{' '}
						<a href={analyticsHref({ includeBots: true })}>Include bots</a>
					</>
				)}
				{' · '}
				<span>{analytics.totalViews.toLocaleString()} public page views in this window</span>
			</p>

			{analytics.error ? (
				<p class="analytics__notice" role="status">
					{analytics.error}
				</p>
			) : null}

			{!analytics.error && analytics.configured && analytics.totalViews === 0 ? (
				<p class="analytics__notice" role="status">
					No public page views in this window yet. After deploy, hit a public HTML page on this
					environment; writes go to dataset <code>{analytics.dataset}</code>.
				</p>
			) : null}

			<nav class="analytics__panels" aria-label="Analytics view">
				<a
					href={analyticsHref({ path: null, panel: 'pages' })}
					class:list={['analytics__panel-tab', { 'is-active': activePanel === 'pages' }]}
					aria-current={activePanel === 'pages' ? 'page' : undefined}
				>
					Pages
				</a>
				<a
					href={analyticsHref({
						panel: 'countries',
						path: selectedPath,
					})}
					class:list={['analytics__panel-tab', { 'is-active': activePanel === 'countries' }]}
					aria-current={activePanel === 'countries' ? 'page' : undefined}
				>
					Countries
				</a>
			</nav>

			<div class="analytics__grid" data-panel={activePanel}>
				<div class="analytics__panel analytics__panel--pages">
					<h3>Top public pages</h3>
					{analytics.topPages.length === 0 ? (
						<p class="analytics__empty">No page data.</p>
					) : (
						<table>
							<thead>
								<tr>
									<th scope="col">Path</th>
									<th scope="col">Views</th>
								</tr>
							</thead>
							<tbody>
								{analytics.topPages.map((row) => {
									const isSelected = selectedPath === row.key;
									return (
										<tr class:list={{ 'is-selected': isSelected }}>
											<td>
												<a
													href={analyticsHref({
														path: isSelected ? null : row.key,
														panel: isSelected ? 'pages' : 'countries',
													})}
													class="analytics__path-link"
													aria-current={isSelected ? 'true' : undefined}
												>
													<code>{row.key}</code>
												</a>
											</td>
											<td>{row.views.toLocaleString()}</td>
										</tr>
									);
								})}
							</tbody>
						</table>
					)}
					{selectedPath ? (
						<p class="analytics__hint analytics__hint--desktop">
							Showing countries for <code>{selectedPath}</code>.{' '}
							<a href={analyticsHref({ path: null, panel: 'pages' })}>Clear selection</a>
						</p>
					) : (
						<p class="analytics__hint analytics__hint--desktop">
							Select a path to break down views by country.
						</p>
					)}
				</div>

				<div class="analytics__panel analytics__panel--countries">
					<div class="analytics__panel-toolbar">
						<a
							href={analyticsHref({ path: null, panel: 'pages' })}
							class="analytics__back-pages"
						>
							← Pages
						</a>
						{selectedPath ? (
							<a
								href={analyticsHref({ path: null, panel: 'countries' })}
								class="analytics__clear-path"
							>
								All countries
							</a>
						) : null}
					</div>
					{selectedPath ? (
						<h3>
							Countries for <code>{selectedPath}</code>
						</h3>
					) : (
						<h3>By country</h3>
					)}
					{countryRows.length === 0 ? (
						<p class="analytics__empty">
							{selectedPath
								? 'No country data for this path in this window.'
								: 'No country data.'}
						</p>
					) : (
						<table>
							<thead>
								<tr>
									<th scope="col">Country</th>
									<th scope="col">Views</th>
								</tr>
							</thead>
							<tbody>
								{countryRows.map((row) => (
									<tr>
										<td>
											<AnalyticsCountryLabel code={row.key} />
										</td>
										<td>{row.views.toLocaleString()}</td>
									</tr>
								))}
							</tbody>
						</table>
					)}
					{selectedPath ? (
						<p class="analytics__hint analytics__hint--desktop">
							<a href={analyticsHref({ path: null })}>Clear selection</a> to see site-wide
							countries.
						</p>
					) : null}
				</div>
			</div>
		</section>
	</article>
</Layout>

<style>
	.analytics-admin {
		max-width: var(--max-width-article);
		margin: 0 auto;
		padding: var(--page-padding-top) var(--page-padding-side) 4rem;
	}

	.back {
		margin: 0 0 1rem;
		font-size: 0.92rem;
	}

	.back a {
		color: #0044bb;
		text-decoration: none;
		font-weight: 600;
	}

	.back a:hover,
	.back a:focus-visible {
		text-decoration: underline;
	}

	h1 {
		margin: 0 0 1.5rem;
		font-family: 'Playfair Display', Georgia, serif;
		font-weight: 900;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1;
		letter-spacing: -0.02em;
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.analytics {
		margin: 0;
		padding: 1.25rem 1.35rem 1.5rem;
		border: 1px solid var(--border-subtle);
		border-radius: 8px;
		background: #fafafa;
	}

	.analytics__eyebrow {
		margin: 0 0 0.55rem;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: #0044bb;
	}

	.analytics__meta {
		margin: 0 0 1rem;
		font-size: 0.92rem;
		line-height: 1.5;
		color: var(--text-secondary);
	}

	.analytics__meta code {
		font-size: 0.85em;
	}

	.analytics__ranges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0 0 0.85rem;
	}

	.analytics__range {
		display: inline-block;
		padding: 0.35rem 0.75rem;
		border: 1px solid var(--border-subtle);
		border-radius: 6px;
		background: #fff;
		color: inherit;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 600;
	}

	.analytics__range.is-active {
		border-color: #0044bb;
		color: #0044bb;
		box-shadow: 0 0 0 1px rgba(0, 68, 187, 0.2);
	}

	.analytics__filters {
		margin: 0 0 1rem;
		font-size: 0.9rem;
		line-height: 1.5;
		color: var(--text-secondary);
	}

	.analytics__filters a {
		color: #0044bb;
	}

	.analytics__notice {
		margin: 0 0 1rem;
		padding: 0.75rem 0.9rem;
		border-left: 3px solid #c45c00;
		background: #fff7ef;
		font-size: 0.92rem;
		line-height: 1.5;
	}

	.analytics__notice code {
		font-size: 0.85em;
	}

	.analytics__panels {
		display: none;
		gap: 0.5rem;
		margin: 0 0 1rem;
	}

	.analytics__panel-tab {
		flex: 1 1 0;
		display: inline-block;
		padding: 0.4rem 0.75rem;
		border: 1px solid var(--border-subtle);
		border-radius: 6px;
		background: #fff;
		color: inherit;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 600;
		text-align: center;
	}

	.analytics__panel-tab.is-active {
		border-color: #0044bb;
		color: #0044bb;
		box-shadow: 0 0 0 1px rgba(0, 68, 187, 0.2);
	}

	.analytics__panel-toolbar {
		display: none;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin: 0 0 0.65rem;
		font-size: 0.9rem;
	}

	.analytics__back-pages,
	.analytics__clear-path {
		color: #0044bb;
		text-decoration: none;
		font-weight: 600;
	}

	.analytics__back-pages:hover,
	.analytics__back-pages:focus-visible,
	.analytics__clear-path:hover,
	.analytics__clear-path:focus-visible {
		text-decoration: underline;
	}

	.analytics__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.25rem;
	}

	.analytics__panel h3 {
		margin: 0 0 0.65rem;
		font-size: 1rem;
		font-weight: 700;
	}

	.analytics__panel h3 code {
		font-size: 0.9em;
		font-weight: 600;
		word-break: break-all;
	}

	.analytics__empty {
		margin: 0;
		font-size: 0.92rem;
		color: var(--text-secondary);
	}

	.analytics__hint {
		margin: 0.75rem 0 0;
		font-size: 0.86rem;
		line-height: 1.45;
		color: var(--text-secondary);
	}

	.analytics__hint a {
		color: #0044bb;
	}

	.analytics__hint code {
		font-size: 0.9em;
		word-break: break-all;
	}

	.analytics__panel table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.92rem;
	}

	.analytics__panel th,
	.analytics__panel td {
		padding: 0.4rem 0.35rem;
		border-bottom: 1px solid var(--border-subtle);
		text-align: left;
		vertical-align: top;
	}

	.analytics__panel th:first-child,
	.analytics__panel td:first-child {
		max-width: 12.5rem;
	}

	.analytics__panel th:last-child,
	.analytics__panel td:last-child {
		text-align: right;
		white-space: nowrap;
		font-variant-numeric: tabular-nums;
	}

	.analytics__panel tr.is-selected td {
		background: rgba(0, 68, 187, 0.06);
	}

	.analytics__path-link {
		color: inherit;
		text-decoration: none;
	}

	.analytics__path-link:hover,
	.analytics__path-link:focus-visible {
		color: #0044bb;
		text-decoration: underline;
	}

	.analytics__path-link[aria-current='true'] {
		color: #0044bb;
		font-weight: 600;
	}

	.analytics__panel code {
		font-size: 0.86em;
		word-break: break-all;
	}

	@media (max-width: 719px) {
		.analytics__panels {
			display: flex;
		}

		.analytics__panel-toolbar {
			display: flex;
		}

		.analytics__hint--desktop {
			display: none;
		}

		.analytics__grid {
			grid-template-columns: 1fr;
		}

		.analytics__grid[data-panel='pages'] .analytics__panel--countries {
			display: none;
		}

		.analytics__grid[data-panel='countries'] .analytics__panel--pages {
			display: none;
		}
	}

	@media (min-width: 720px) {
		.analytics__panels,
		.analytics__panel-toolbar {
			display: none;
		}
	}
</style>
