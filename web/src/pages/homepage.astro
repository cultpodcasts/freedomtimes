---
import HomepageView from '../components/HomepageView.astro';
import { isLockedSiteAccess, SESSION_COOKIE } from '../lib/auth';
import {
  getOptionalEditorialSession,
  requireEditorialSession,
} from '../lib/editorial-session';

const isLocked = isLockedSiteAccess();

let isAdmin = false;
let isSignedIn = false;

const sessionContext = {
  cookies: Astro.cookies,
  url: Astro.url,
  request: Astro.request,
  redirect: Astro.redirect,
};

if (isLocked) {
  const token = Astro.cookies.get(SESSION_COOKIE)?.value;

  // Serve the same login screen as `/` without a redirect (embedded browsers
  // were showing a blank page on /homepage after 302 or nested HTML).
  if (!token) {
    return Astro.rewrite('/');
  }

  const session = await requireEditorialSession(sessionContext);

  if (session instanceof Response) {
    return Astro.rewrite('/?denied=1');
  }

  isAdmin = session.isAdmin;
  isSignedIn = true;
} else {
  const session = await getOptionalEditorialSession(sessionContext);
  if (session) {
    isAdmin = session.isAdmin;
    isSignedIn = true;
  }
}
---

<HomepageView isAdmin={isAdmin} isSignedIn={isSignedIn} />
