---
import Layout from '../layouts/Layout.astro';
import { requireEditorialSession } from '../lib/editorial-session';

type Story = {
  slug: string;
  title: string;
  dek: string;
  section: string;
  author: string;
  minutes: number;
};

const session = await requireEditorialSession({
  cookies: Astro.cookies,
  url: Astro.url,
  request: Astro.request,
  redirect: Astro.redirect,
});

if (session instanceof Response) {
  return session;
}

const name = session.displayName;

const stories: Story[] = [
  {
    slug: 'cabinet-culture-briefing',
    title: 'Cabinet Culture Briefing: How fringe narratives reached Whitehall corridors',
    dek: 'A weeklong investigation into influence channels, donor networks, and the new language of authority.',
    section: 'Politics',
    author: 'Martha Ellison',
    minutes: 8,
  },
  {
    slug: 'docklands-quiet-money',
    title: 'The Quiet Money of Docklands: shell companies, empty floors, and invisible ownership',
    dek: 'Property filings and leaked prospectuses reveal a hidden market reshaping east London.',
    section: 'Investigations',
    author: 'Daniel Reeve',
    minutes: 11,
  },
  {
    slug: 'church-square-network',
    title: 'Inside the Church Square Network that feeds Britain\'s viral moral panics',
    dek: 'From Telegram channels to breakfast TV scripts, one media chain is setting the daily tone.',
    section: 'Media',
    author: 'Aisha Khan',
    minutes: 7,
  },
  {
    slug: 'north-sea-farms',
    title: 'North Sea Wind Farms Face Local Revolt as Compensation Talks Collapse',
    dek: 'Village councils are demanding long-term rate guarantees before new construction starts.',
    section: 'Britain',
    author: 'Oliver Page',
    minutes: 5,
  },
  {
    slug: 'city-after-dark-economy',
    title: 'The City After Dark: private members\' clubs become the new policy salons',
    dek: 'Ministers, advisors, and platform founders now prefer invitation-only venues over public forums.',
    section: 'Business',
    author: 'Nadia Porter',
    minutes: 6,
  },
  {
    slug: 'schools-curriculum-wave',
    title: 'Schools Brace for a New Curriculum Wave as Pilot Rules Leak',
    dek: 'Teachers say proposed standards compress arts and civic studies in favor of competency blocks.',
    section: 'Education',
    author: 'Jacob Finch',
    minutes: 4,
  },
];

const lead = stories[0];
const secondLead = stories[1];
const rails = stories.slice(2);
---

<Layout>
  <div class="paper-wrap">
    <header class="masthead">
      <p class="edition">London | Tuesday Edition | Investigations & Public Interest</p>
      <h1>Freedom Times</h1>
      <p class="tagline">The national paper of record for cult power, public money, and manufactured truth.</p>
      <nav>
        <a href="/homepage">Home</a>
        <a href="#">Britain</a>
        <a href="#">Investigations</a>
        <a href="#">Media</a>
        <a href="#">Business</a>
        <a href="/_emdash/admin">CMS</a>
        <a href="/auth/logout">Sign out</a>
      </nav>
      <p class="welcome">Signed in as {name}</p>
    </header>

    <main class="front-grid">
      <article class="lead">
        <p class="kicker">{lead.section}</p>
        <h2>{lead.title}</h2>
        <p>{lead.dek}</p>
        <p class="meta">By {lead.author} | {lead.minutes} min read</p>
      </article>

      <article class="secondary">
        <p class="kicker">{secondLead.section}</p>
        <h3>{secondLead.title}</h3>
        <p>{secondLead.dek}</p>
        <p class="meta">By {secondLead.author} | {secondLead.minutes} min read</p>
      </article>

      <section class="rail">
        {rails.map((story) => (
          <article>
            <p class="kicker">{story.section}</p>
            <h4>{story.title}</h4>
            <p>{story.dek}</p>
          </article>
        ))}
      </section>
    </main>
  </div>
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bodoni+Moda:opsz,wght@6..96,600;6..96,700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,700&display=swap');

  :global(.shell) {
    display: block;
    padding: 0;
  }

  :global(body) {
    background:
      radial-gradient(circle at 20% 0%, #f5ecdc 0%, transparent 44%),
      repeating-linear-gradient(
        90deg,
        rgba(40, 28, 17, 0.02) 0,
        rgba(40, 28, 17, 0.02) 1px,
        transparent 1px,
        transparent 34px
      ),
      #f1e7d5;
    color: #1d1712;
    font-family: 'Source Serif 4', Georgia, serif;
  }

  .paper-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 1.2rem 1.2rem 2rem;
  }

  .masthead {
    border-bottom: 3px double #2e2418;
    padding-bottom: 0.9rem;
    animation: reveal 500ms ease-out;
  }

  .edition,
  .tagline {
    margin: 0;
    text-align: center;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    text-align: center;
    font-family: 'Bodoni Moda', 'Times New Roman', serif;
    font-size: clamp(2.4rem, 7vw, 5.4rem);
    line-height: 1;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .tagline {
    margin-top: 0.35rem;
    margin-bottom: 0.8rem;
    font-size: 0.74rem;
  }

  nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    padding-top: 0.5rem;
    font-weight: 700;
    font-size: 0.92rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  nav a {
    color: #1d1712;
    text-decoration: none;
  }

  .welcome {
    text-align: center;
    margin: 0.7rem 0 0;
    font-size: 0.84rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .front-grid {
    display: grid;
    grid-template-columns: 2fr 1.3fr 1.1fr;
    gap: 1.1rem;
    margin-top: 1rem;
    align-items: start;
  }

  .lead,
  .secondary,
  .rail article {
    background: linear-gradient(170deg, #faf5ea 0%, #efe3cf 100%);
    border: 1px solid #2e2418;
    padding: 0.95rem;
  }

  .lead h2 {
    font-family: 'Bodoni Moda', 'Times New Roman', serif;
    font-size: clamp(1.8rem, 3.2vw, 2.6rem);
    line-height: 1.08;
    margin: 0.25rem 0 0.5rem;
  }

  .secondary h3,
  .rail h4 {
    font-family: 'Bodoni Moda', 'Times New Roman', serif;
    line-height: 1.18;
    margin: 0.2rem 0 0.4rem;
  }

  .secondary h3 {
    font-size: 1.5rem;
  }

  .rail {
    display: grid;
    gap: 0.7rem;
  }

  .rail h4 {
    font-size: 1.17rem;
  }

  .kicker {
    margin: 0;
    font-weight: 700;
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #742312;
  }

  .meta {
    margin-bottom: 0;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 960px) {
    .front-grid {
      grid-template-columns: 1fr;
    }

    .paper-wrap {
      padding-left: 0.75rem;
      padding-right: 0.75rem;
    }

    nav {
      justify-content: flex-start;
    }
  }
</style>
