---
import { PortableText } from 'astro-portabletext';

import Layout from '../layouts/Layout.astro';
import PushNotificationsCallout from './PushNotificationsCallout.astro';

const {
	entry,
	collectionLabel,
	displayName,
	isPreview = false,
} = Astro.props as {
	entry: { id: string; slug?: string; data: Record<string, unknown> };
	collectionLabel: string;
	displayName: string;
	isPreview?: boolean;
};

function readString(value: unknown): string | null {
	return typeof value === 'string' && value.trim().length > 0 ? value : null;
}

function readFeaturedImageSrc(value: unknown): string | null {
	if (typeof value === 'string') {
		const trimmed = value.trim();
		return trimmed.length > 0 ? trimmed : null;
	}

	if (value && typeof value === 'object') {
		const candidate = value as Record<string, unknown>;
		return readString(candidate.src) ?? readString(candidate.url) ?? null;
	}

	return null;
}

const data = entry.data;
const title =
	readString(data.title) ??
	readString(data.name) ??
	readString(data.headline) ??
	readString(entry.slug) ??
	'Untitled';
const summary =
	readString(data.dek) ?? readString(data.excerpt) ?? readString(data.description) ?? null;
const portableContent = Array.isArray(data.content) ? data.content : null;
const textContent = portableContent ? null : readString(data.content);
const featuredImageSrc = readFeaturedImageSrc(data.featured_image);
const featuredImageAlt = readString(data.featured_image_alt) ?? `${title} featured image`;
const publishedAt = readString(data.publishedAt);
const updatedAt = readString(data.updatedAt);
---

<Layout>
	<article class="page-wrap">
		<header class="masthead">
			<div>
				<p class="eyebrow">{collectionLabel}</p>
				<h1>{title}</h1>
				{summary && <p class="summary">{summary}</p>}
			</div>
			<div class="meta-block">
				<p>Signed in as {displayName}</p>
				{publishedAt && <p>Published {new Date(publishedAt).toLocaleString()}</p>}
				{!publishedAt && updatedAt && <p>Updated {new Date(updatedAt).toLocaleString()}</p>}
				{isPreview && <p class="preview">Preview mode</p>}
				<nav>
					<a href="/homepage">Home</a>
					<a href="/_emdash/admin">CMS</a>
					<a href="/auth/logout">Sign out</a>
				</nav>
			</div>
		</header>

		<section class="content-card">
			{featuredImageSrc && (
				<figure class="hero">
					<img src={featuredImageSrc} alt={featuredImageAlt} loading="eager" decoding="async" />
				</figure>
			)}
			{portableContent && portableContent.length > 0 && <PortableText value={portableContent} />}
			{!portableContent && textContent && <p>{textContent}</p>}
			{!portableContent && !textContent && (
				<p class="empty-state">This entry is published but has no renderable body content yet.</p>
			)}
			<PushNotificationsCallout />
		</section>
	</article>
</Layout>

<style>
	:global(.shell) {
		display: block;
		padding: 0;
	}

	:global(body) {
		background:
			radial-gradient(circle at top left, rgba(248, 236, 211, 0.9), transparent 32%),
			linear-gradient(180deg, #f5ecd9 0%, #efe4cf 100%);
		color: #1f1a15;
		font-family: Georgia, 'Times New Roman', serif;
	}

	.page-wrap {
		max-width: 860px;
		margin: 0 auto;
		padding: 2rem 1.25rem 3rem;
	}

	.masthead {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: end;
		border-bottom: 3px double #33271c;
		padding-bottom: 1rem;
		margin-bottom: 1.5rem;
	}

	.eyebrow,
	.meta-block p {
		margin: 0;
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0.2rem 0 0;
		font-size: clamp(2.2rem, 6vw, 4.25rem);
		line-height: 0.95;
		font-family: 'Times New Roman', Georgia, serif;
	}

	.summary {
		margin: 0.8rem 0 0;
		font-size: 1.08rem;
		line-height: 1.6;
		max-width: 62ch;
	}

	.meta-block {
		display: grid;
		gap: 0.45rem;
		justify-items: end;
		text-align: right;
	}

	.preview {
		color: #7b2f17;
		font-weight: 700;
	}

	nav {
		display: flex;
		gap: 0.9rem;
		flex-wrap: wrap;
		justify-content: end;
	}

	nav a {
		color: #1f1a15;
		text-decoration: none;
		font-weight: 700;
	}

	.content-card {
		padding: 1.75rem;
		background: rgba(255, 252, 245, 0.85);
		border: 1px solid rgba(61, 44, 27, 0.18);
		box-shadow: 0 18px 40px rgba(60, 42, 21, 0.1);
		border-radius: 18px;
		line-height: 1.75;
		font-size: 1.05rem;
	}

	.hero {
		margin: 0 0 1.2rem;
	}

	.hero img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 12px;
		border: 1px solid rgba(61, 44, 27, 0.2);
		background: #f2ebde;
	}

	.content-card :global(p) {
		margin: 0 0 1rem;
	}

	.content-card :global(h2),
	.content-card :global(h3),
	.content-card :global(h4) {
		font-family: 'Times New Roman', Georgia, serif;
		line-height: 1.1;
		margin: 1.75rem 0 0.8rem;
	}

	.content-card :global(a) {
		color: #234d69;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.14em;
	}

	.empty-state {
		margin: 0;
		font-style: italic;
		color: #5d5144;
	}

	@media (max-width: 760px) {
		.masthead {
			grid-template-columns: 1fr;
		}

		.meta-block {
			justify-items: start;
			text-align: left;
		}

		nav {
			justify-content: start;
		}

		.content-card {
			padding: 1.2rem;
		}
	}
</style>