---
const props = Astro.props as Record<string, unknown>;
const value =
	(props.value as Record<string, unknown> | undefined)
	?? ((props.node as Record<string, unknown> | undefined)?.markDef as Record<string, unknown> | undefined)
	?? (props.markDef as Record<string, unknown> | undefined)
	?? (props.mark as Record<string, unknown> | undefined)
	?? props;

const href = typeof value?.href === 'string' && value.href.trim().length > 0 ? value.href.trim() : '#';
const isExternal = /^https?:\/\//i.test(href);
const target = isExternal ? '_blank' : undefined;
const rel = isExternal ? 'noopener noreferrer' : undefined;
---

<a href={href} target={target} rel={rel}>
	<slot />
</a>
