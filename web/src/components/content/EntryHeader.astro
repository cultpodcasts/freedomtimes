---
import type { SubjectChip } from '../../lib/content/contentEntry';

const {
	title,
	issueDate,
	primaryByline,
	publishedAt,
	updatedAt,
	isPreview = false,
	subjectChips = [],
} = Astro.props as {
	title: string;
	issueDate: string | null;
	primaryByline: string | null;
	publishedAt: string | null;
	updatedAt: string | null;
	isPreview?: boolean;
	subjectChips: SubjectChip[];
};

function formatShortDate(value: string): string {
	const parsed = new Date(value);
	if (Number.isNaN(parsed.getTime())) {
		return value;
	}
	return parsed.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
}

/** Show Updated when CMS metadata changed after first publication. */
function shouldShowUpdatedDate(publishedAt: string | null, updatedAt: string | null): boolean {
	if (!updatedAt) return false;
	if (!publishedAt) return true;
	const updated = new Date(updatedAt);
	const published = new Date(publishedAt);
	if (Number.isNaN(updated.getTime()) || Number.isNaN(published.getTime())) return false;
	if (updated.toDateString() !== published.toDateString()) {
		return updated > published;
	}
	return updated.getTime() - published.getTime() > 60_000;
}

const showUpdatedDate = shouldShowUpdatedDate(publishedAt, updatedAt);
---

<header class="article-header">
	<h1>{title}</h1>
	{issueDate && <p class="issue-date">Issue date {new Date(issueDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>}

	<div class="article-meta">
		{primaryByline && <p>By {primaryByline}</p>}
		{publishedAt && <p>Published {formatShortDate(publishedAt)}</p>}
		{showUpdatedDate && updatedAt && <p>Updated {formatShortDate(updatedAt)}</p>}
		{isPreview && <p class="preview">Preview mode</p>}
	</div>
	{subjectChips.length > 0 && (
		<ul class="subject-list" aria-label="Subjects">
			{subjectChips.map((chip) => <li style={chip.style}>{chip.label}</li>)}
		</ul>
	)}
</header>
