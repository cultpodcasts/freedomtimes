# Example production-only local env overlay
# Copy to .env.production and fill real values
# Local dev reads these keys directly. Do not use prefixed alias names.

# [github-secrets]
AUTH0_LOGIN_APP_CLIENT_ID=<freedomtimes-production app client-id>
AUTH0_LOGIN_APP_CLIENT_SECRET=<freedomtimes-production app client-secret>
TF_VAR_api_custom_hostname_certificate_base64=
TF_VAR_api_custom_hostname_certificate_password=

# [github-vars]
TF_VAR_manage_apex_dns_record=true
TF_VAR_apex_dns_record_content=192.0.2.1
TF_VAR_api_custom_hostname=api.example.com
AUTH0_API_AUDIENCE=https://api.example.com
API_BASE_URL=https://api.example.com/editorial
COOKIE_BASE_DOMAIN=example.com
AUTH0_ROLES_CLAIM_NAMESPACE=https://example.com
API_UPSTREAM_MODE=apim

# [cloudflare-worker-secrets]
AUTH0_DOMAIN=<auth0-tenant>.uk.auth0.com
AUTH0_CLIENT_ID=<freedomtimes-production app client-id>
AUTH0_CLIENT_SECRET=<freedomtimes-production app client-secret>
